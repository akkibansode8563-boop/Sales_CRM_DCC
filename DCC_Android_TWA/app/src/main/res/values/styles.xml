<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!--
        Main app theme — inherits from AppCompat (requires appcompat dependency).
        Theme.AppCompat.Light.NoActionBar is safe on all API levels 21+.
    -->
    <style name="Theme.DCC.Launcher" parent="Theme.AppCompat.Light.NoActionBar">
        <!-- Splash / window background shown before PWA loads -->
        <item name="android:windowBackground">@color/backgroundColor</item>

        <!-- Status bar — DCC brand blue -->
        <item name="android:statusBarColor">@color/colorPrimary</item>

        <!-- Bottom navigation bar -->
        <item name="android:navigationBarColor">@color/navigationColor</item>

        <!-- Light icons on dark status bar -->
        <item name="android:windowLightStatusBar">false</item>

        <!-- Allow drawing behind system bars for edge-to-edge feel -->
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>

        <!-- No title / action bar -->
        <item name="android:windowNoTitle">true</item>
        <item name="windowActionBar">false</item>

        <!-- Prevent white flash on launch -->
        <item name="android:windowIsTranslucent">false</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>

    <!--
        Splash screen theme — fullscreen until TWA content loads.
        Used by the LauncherActivity while Chrome/Custom Tab initialises.
    -->
    <style name="Theme.DCC.Splash" parent="Theme.DCC.Launcher">
        <item name="android:windowFullscreen">true</item>
    </style>

</resources>
